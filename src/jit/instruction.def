// Representative authoritative schema for Core JIT instruction kinds.
//
// This file deliberately describes semantic payload rather than physical slot
// placement. Repeated includers define the CL_JIT_* macros to generate or
// validate kinds, typed views, factories, effect bounds, operand traversal,
// attributes, and candidate physical layouts.
//
// CL_JIT_INSTRUCTION arguments:
//   name, IR levels, result, effect bounds, operands, attributes
//
// CL_JIT_OPERAND arguments:
//   name                 typed-accessor and diagnostic name
//   operand class        ProgramValue or Snapshot
//   representation      TaggedValue or F64 for ProgramValue; None for Snapshot
//
// Result class and representation are encoded in the upper bits of the
// generated InstructionKind. A separately generated dense ordinal indexes
// compact metadata tables.
//
// Every ProgramValue operand may hold either a result reference or an inline
// constant with the matching representation. Backend legalization decides
// whether a selected lowering may retain that constant at that use. Other
// operand classes contain result references. CL_JIT_VARIADIC_OPERAND has the
// same three arguments. A kind with any variadic operand stores its entire
// operand sequence in arena-owned storage behind inline slot zero; attributes
// retain kind-constant inline offsets beginning at slot one. The variadic range
// is always declared after every fixed operand, so fixed operands retain
// kind-constant indices within the indirect sequence.
// SnapshotValues is the one annotated heterogeneous variable payload described
// by the instruction representation.
//
// CL_JIT_ATTRIBUTE arguments:
//   name, attribute class

CL_JIT_INSTRUCTION(
    Parameter,
    CL_JIT_IR_LEVELS(Core),
    CL_JIT_RESULT(ProgramValue, TaggedValue),
    CL_JIT_EFFECT_BOUNDS(None, None),
    CL_JIT_OPERANDS(),
    CL_JIT_ATTRIBUTES())

CL_JIT_INSTRUCTION(
    ParameterF64,
    CL_JIT_IR_LEVELS(Core),
    CL_JIT_RESULT(ProgramValue, F64),
    CL_JIT_EFFECT_BOUNDS(None, None),
    CL_JIT_OPERANDS(),
    CL_JIT_ATTRIBUTES())

CL_JIT_INSTRUCTION(
    Mov,
    CL_JIT_IR_LEVELS(Core),
    CL_JIT_RESULT(ProgramValue, TaggedValue),
    CL_JIT_EFFECT_BOUNDS(None, None),
    CL_JIT_OPERANDS(
        CL_JIT_OPERAND(value, ProgramValue, TaggedValue)),
    CL_JIT_ATTRIBUTES())

CL_JIT_INSTRUCTION(
    MovF64,
