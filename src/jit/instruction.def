#define CL_JIT_Snapshot_OPERANDS(fixed, variadic, snapshot_values)            \
    snapshot_values(captured_values)
#define CL_JIT_Snapshot_ATTRIBUTES(attribute) attribute(resume_pc, BytecodePC)
CL_JIT_INSTRUCTION(Snapshot, CL_JIT_IR_LEVELS(Core),
                   CL_JIT_RESULT(Snapshot, None),
                   CL_JIT_EFFECT_BOUNDS(None, None), CL_JIT_Snapshot_OPERANDS,
                   CL_JIT_Snapshot_ATTRIBUTES)
