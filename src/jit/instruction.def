    CL_JIT_EFFECT_BOUNDS(None, None),
    CL_JIT_OPERANDS(
        CL_JIT_OPERAND(value, ProgramValue, F64)),
    CL_JIT_ATTRIBUTES())

CL_JIT_INSTRUCTION(
    AddSMI,
    CL_JIT_IR_LEVELS(Core),
    CL_JIT_RESULT(ProgramValue, TaggedValue),
    CL_JIT_EFFECT_BOUNDS(None, Deoptimize),
    CL_JIT_OPERANDS(
        CL_JIT_OPERAND(lhs, ProgramValue, TaggedValue),
        CL_JIT_OPERAND(rhs, ProgramValue, TaggedValue),
        CL_JIT_OPERAND(snapshot, Snapshot, None)),
    CL_JIT_ATTRIBUTES())

