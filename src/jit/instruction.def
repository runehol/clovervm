// Representative authoritative schema for Core JIT instruction kinds.
//
// Each operand-list macro accepts callbacks for fixed operands, a trailing
// homogeneous variadic range, and Snapshot's heterogeneous capture range. Each
// attribute-list macro accepts one attribute callback. Keeping the lists as
// reusable callbacks lets repeated includers derive indices, accessors,
// traversal, constructors, and metadata from declaration order.
//
// CL_JIT_INSTRUCTION arguments:
//   name, IR levels, result, effect bounds, operand-list, attribute-list
//
// Fixed and variadic operand callbacks receive:
//   name, operand class, representation
//
// Attribute callbacks receive:
//   name, attribute class
//
// Result class and representation are encoded in the upper bits of the
// generated InstructionKind. A separately generated dense ordinal indexes
// compact metadata tables.
//
// Every operand is a reference to an instruction result. ProgramValue operands
// additionally require the declared representation. Constants enter ordinary
// dataflow, including Snapshot capture, through Const definitions.
//
// A kind with any variadic operand stores its operand payloads in arena-owned
// storage behind inline slot zero; attributes retain kind-constant inline
// offsets beginning at slot one. The variadic range is always declared after
// every fixed operand, so fixed operands retain kind-constant indices within
// the indirect sequence. Snapshot appends one descriptor word per captured
// payload after the complete payload array.

#define CL_JIT_Parameter_OPERANDS(fixed, variadic, snapshot_values)
#define CL_JIT_Parameter_ATTRIBUTES(attribute)
CL_JIT_INSTRUCTION(Parameter, CL_JIT_IR_LEVELS(Core),
                   CL_JIT_RESULT(ProgramValue, TaggedValue),
                   CL_JIT_EFFECT_BOUNDS(None, None),
                   CL_JIT_Parameter_OPERANDS, CL_JIT_Parameter_ATTRIBUTES)
#undef CL_JIT_Parameter_ATTRIBUTES
#undef CL_JIT_Parameter_OPERANDS

#define CL_JIT_ParameterF64_OPERANDS(fixed, variadic, snapshot_values)
#define CL_JIT_ParameterF64_ATTRIBUTES(attribute)
CL_JIT_INSTRUCTION(ParameterF64, CL_JIT_IR_LEVELS(Core),
                   CL_JIT_RESULT(ProgramValue, F64),
                   CL_JIT_EFFECT_BOUNDS(None, None),
                   CL_JIT_ParameterF64_OPERANDS,
                   CL_JIT_ParameterF64_ATTRIBUTES)
#undef CL_JIT_ParameterF64_ATTRIBUTES
#undef CL_JIT_ParameterF64_OPERANDS

#define CL_JIT_Mov_OPERANDS(fixed, variadic, snapshot_values)                 \
    fixed(source, ProgramValue, TaggedValue)
#define CL_JIT_Mov_ATTRIBUTES(attribute)
CL_JIT_INSTRUCTION(Mov, CL_JIT_IR_LEVELS(Core),
                   CL_JIT_RESULT(ProgramValue, TaggedValue),
                   CL_JIT_EFFECT_BOUNDS(None, None), CL_JIT_Mov_OPERANDS,
                   CL_JIT_Mov_ATTRIBUTES)
